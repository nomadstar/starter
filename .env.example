# API Keys for AI Plugins
# Copia este archivo a ".env" y reemplaza los valores
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
TOGETHER_API_KEY=""
# Si tienes un binario de Ollama customizado, configura la ruta:
# OLLAMA_CMD=".../route/this/path"
# OLLAMA_HOST="http://localhost:11434"

# --- Telegram Bot (Control Remoto) ---
#TELEGRAM_BOT_TOKEN="tu_token_aqui"
#TELEGRAM_CHAT_ID="tu_chat_id_aqui"

# --- Configuración Orquestador Multi-Agente ---
#AGENT_MAX_ITERATIONS="3"
#AGENT_CLOUD_MODEL="openai,gpt-oss-120b,other_model"
#AGENT_LOCAL_MODEL="llama3"

# --- Control de Potencia (Tokens) ---
# Límite de tokens de salida para el Arquitecto Cloud (default conservador: 4096)
#AGENT_MAX_OUTPUT_TOKENS="8192"
# Presupuesto de tokens de la sesión (Seguridad para que no te cobren de más)
#AGENT_TOKEN_BUDGET="50000"
# Modelos 100% gratuitos ($0) requeridos para aprobar código en MidnightMonster
#AGENT_NIGHTLY_FREE_MODELS="meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-coder:free"
# Límite de tokens de salida para el Desarrollador Local Ollama (default: 4096)
#AGENT_LOCAL_MAX_PREDICT="4096"
# Ventana de contexto máxima para Ollama (default: 16384). Auméntalo si Ollama corta archivos.
#AGENT_LOCAL_MAX_CTX="16384"

# --- Modos del Router ---
# 1 = Full Cloud | 2 = Full Local | 3 = Iterative (Orquestador) | 4 = Fallback (Métricas)
# AI_ROUTER_MODE="4"
# Activa la compresión de tokens estilo cavernícola (true/false)
# CAVEMAN_MODE="true"
# Modo nocturno autónomo (omite la aprobación humana de 10 PM a 8 AM)
MIDNIGHT_MONSTER="false"
# --- Asistente de Atención (Noisy Mode) ---
AGENT_NOISY_MODE="true"
AGENT_SOUND_PATH="/usr/share/sounds/freedesktop/stereo/message.oga"
AGENT_SOUND_INTERVAL="5"

# Telegram Token
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""